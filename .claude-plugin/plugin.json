{
  "name": "korean-law",
  "version": "4.0.6",
  "description": "법제처 42개 API → 17개 MCP 도구. 법령·판례·조례·조약 + LLM 환각 방지 인용 검증 + 조문 영향 그래프 + 시점 비교 diff + 상황별 5단계 안내",
  "author": {
    "name": "Chris",
    "email": "ryuseungin@gmail.com",
    "url": "https://github.com/chrisryugj"
  },
  "homepage": "https://github.com/chrisryugj/korean-law-mcp",
  "repository": "https://github.com/chrisryugj/korean-law-mcp",
  "license": "MIT",
  "keywords": [
    "korean-law",
    "법령",
    "판례",
    "법제처",
    "legal-ai",
    "mcp"
  ],
  "mcpServers": {
    "korean-law": {
      "command": "npx",
      "args": ["-y", "korean-law-mcp@latest"],
      "env": {
        "LAW_OC": "${user_config.api_key}"
      }
    }
  },
  "userConfig": {
    "api_key": {
      "type": "string",
      "title": "법제처 API 키 (LAW_OC)",
      "description": "법제처 OpenAPI 인증키. https://open.law.go.kr/LSO/openApi/guideResult.do 에서 무료 발급 (예: honggildong)",
      "sensitive": true
    }
  }
}
